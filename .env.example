# Neon PostgreSQL
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"

# Clerk
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# Perplexity
PERPLEXITY_API_KEY=""

# Apify
APIFY_API_TOKEN=""

# Slack
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_APP_TOKEN=""

# Zoho CRM
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REFRESH_TOKEN=""

# Cron security (random string to protect cron endpoints)
CRON_SECRET=""

# Token encryption (32+ character key for encrypting OAuth tokens at rest)
TOKEN_ENCRYPTION_KEY=""

# Google (GSC + GA4 — required for SEO/CRO)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# IndexNow (optional — SEO reindex submissions)
INDEXNOW_API_KEY=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# HubSpot CRM (optional)
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# Salesforce CRM (optional)
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""

# App
NODE_ENV="development"
